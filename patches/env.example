# Copy this file to .env and fill in real values.
# .env is gitignored. NEVER commit real secrets.

# ---- Database ----
DB_DSN="mysql:host=localhost;dbname=nxt_backend"
DB_USERNAME=root
DB_PASSWORD=

# ---- Yii cookie validation ----
# Generate a random 32+ char string. Required for cookie/session security.
COOKIE_VALIDATION_KEY=

# ---- SendGrid SMTP (mailer) ----
# Get from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=

# ---- Google Maps ----
# Get from https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=

# ---- Firebase service-account JSONs ----
# Store outside the repo (e.g. ~/.config/nxtschools/) and set absolute paths.
FIREBASE_NXTSCHOOL_KEY_PATH=
FIREBASE_ESTUDENT_KEY_PATH=

# ---- AI providers (AI Timetable & other AI tools) ----
# Configure EITHER provider — or neither: every AI feature has a
# deterministic fallback and works with no key at all.
# Priority when both are set: Anthropic, then Gemini.

# Anthropic Claude — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google Gemini — https://aistudio.google.com/apikey (free tier available)
# NOTE: gemini-2.0-flash free tier is now capped at 0 on new projects — use 2.5.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Gemini 2.5 are reasoning models; keep thinking OFF (0) for the timetable's
# JSON-extraction + short-narration tasks — faster, cheaper, no truncation.
GEMINI_THINKING_BUDGET=0
